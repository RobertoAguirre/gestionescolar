# MongoDB Atlas
MONGODB_URI=tu_url_de_mongodb_atlas_aqui

# Anthropic API
ANTHROPIC_API_KEY=tu_clave_api_de_anthropic_aqui

# Auth
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_unico
JWT_EXPIRES_IN=12h
ADMIN_PASSWORD=define_un_password_seguro
SUPER_ADMIN_PASSWORD=define_un_password_super_admin_seguro
# Opcional: usar hash bcrypt en lugar de password plano
# ADMIN_PASSWORD_HASH=$2a$10$...
# SUPER_ADMIN_PASSWORD_HASH=$2a$10$...

# Server
PORT=3000
NODE_ENV=development

# Stripe (activar cuando se integre checkout)
# STRIPE_SECRET_KEY=sk_live_o_sk_test
# STRIPE_PUBLIC_KEY=pk_live_o_pk_test
